{
  "name": "sulaiman-cv",
  "version": "1.0.0",
  "description": "Sulaiman Hashimi — Test Automation Engineer CV website",
  "scripts": {
    "start": "npx serve application --listen 3000",
    "dev": "npx serve application --listen 3000",
    "test": "npx playwright test --config testing/playwright.config.ts",
